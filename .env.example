# =============================================================================
# Photon Geocoder – .env.example
# Copy to .env and edit as needed.
# =============================================================================

# ── Which Photon version to build ────────────────────────────────────────────
PHOTON_VERSION=0.7.4

# ── Region / country ─────────────────────────────────────────────────────────
# ISO-3166-1 alpha-2 code, continent name, or "planet"
#
# Country examples  : de  fr  es  it  pt  gb  us  ca  br  jp  au  za ...
# Continent examples: europe  asia  africa  north-america  south-america  oceania
# Full world        : planet
REGION=de

# ── Data type ────────────────────────────────────────────────────────────────
# db   → pre-compiled photon_data tar.bz2  (faster, less disk needed during dl)
# dump → .jsonl.zst dump + import          (richer: more languages, geometries)
DATA_TYPE=db

# ── Auto-download ─────────────────────────────────────────────────────────────
AUTO_DOWNLOAD=true

# ── Languages (only used with DATA_TYPE=dump) ─────────────────────────────────
LANGUAGES=en,de,fr,es

# ── Java memory ───────────────────────────────────────────────────────────────
# Small country  :  -Xmx1g
# Large country  :  -Xmx2g
# Continent      :  -Xmx4g
# Planet         :  -Xmx8g
JAVA_OPTS=-Xmx2g -Xms512m

# ── Extra Photon flags ────────────────────────────────────────────────────────
# e.g. PHOTON_OPTS=-cors-any
PHOTON_OPTS=

# ── Port exposed on the host ─────────────────────────────────────────────────
HOST_PORT=2322

# ── Container memory limits ──────────────────────────────────────────────────
MEMORY_LIMIT=4g
MEMORY_RESERVATION=1g

# ── Download options ──────────────────────────────────────────────────────────
BASE_URL=https://download1.graphhopper.com/public
SKIP_MD5=false
